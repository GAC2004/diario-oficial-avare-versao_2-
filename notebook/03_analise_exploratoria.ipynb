      "source": [
        "import numpy as np\n",
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "\n",
        "emb=np.load('../data/embeddings.npy')\n",
        "print('Shape:', emb.shape)\n",
        "print(cosine_similarity([emb[0]], emb[:5]))\n"
      ]
